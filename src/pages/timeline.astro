---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import StatusBadge from "../components/StatusBadge.astro";

const entries = (await getCollection("timeline")).sort(
  (a, b) => b.data.sort - a.data.sort,
);
---

<Layout title="Timeline — Artem Zagaynov">
  <section class="container-page py-16 sm:py-24">
    <header class="mb-12 max-w-2xl">
      <h1 class="section-heading text-4xl sm:text-5xl">Timeline</h1>
      <p class="mt-4 text-lg text-[var(--color-muted)]">
        Where I've been building, most recent first.
      </p>
    </header>

    <ol class="relative border-l border-[var(--color-border)] pl-8">
      {
        entries.map((e) => (
          <li class="relative mb-10 last:mb-0">
            <span
              class:list={[
                "absolute -left-[2.6rem] top-1 grid h-5 w-5 place-items-center rounded-full ring-4 ring-[var(--color-bg)]",
                e.data.status === "in-progress"
                  ? "bg-[var(--color-amber)]"
                  : "bg-[var(--color-accent)]",
              ]}
            />
            <div class="flex flex-wrap items-center gap-3">
              <span class="font-mono text-sm text-[var(--color-amber)]">
                {e.data.year}
              </span>
              <StatusBadge status={e.data.status} />
            </div>
            <h3 class="mt-1 text-xl font-semibold text-[var(--color-fg)]">
              {e.data.title}
            </h3>
            <p class="mt-1 text-[var(--color-muted)]">{e.data.subtitle}</p>
          </li>
        ))
      }
    </ol>
  </section>
</Layout>
