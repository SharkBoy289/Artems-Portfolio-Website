---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found — Artem Zagaynov" description="That page doesn't exist.">
  <section class="container-page flex min-h-[70vh] flex-col items-center justify-center text-center">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-[var(--color-accent)]">
      404
    </p>
    <h1 class="mt-3 text-4xl font-extrabold tracking-tight sm:text-5xl">
      This page wandered off.
    </h1>
    <p class="mt-4 max-w-md text-lg text-[var(--color-muted)]">
      The page you're looking for doesn't exist — or moved. Let's get you back
      to something real.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="/" class="btn-primary">Back home</a>
      <a
        href="/projects"
        class="rounded-full px-6 py-3 font-semibold text-[var(--color-fg)] ring-1 ring-[var(--color-border)] transition-colors hover:ring-[var(--color-accent)]"
      >
        See my work
      </a>
    </div>
  </section>
</Layout>
