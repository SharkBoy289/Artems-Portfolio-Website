---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import HeroBackground from "../components/HeroBackground.astro";
import ProjectCard from "../components/ProjectCard.astro";

const featured = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout>
  <!-- HERO -->
  <section
    class="relative flex min-h-[82vh] items-center justify-center overflow-hidden"
  >
    <HeroBackground />

    <div class="hero-rise container-page flex flex-col items-center text-center">
      <img
        src="/photos/artem-headshot.jpg"
        alt="Artem Zagaynov"
        width="176"
        height="176"
        fetchpriority="high"
        style="--hero-i: 0"
        class="mb-7 h-32 w-32 rounded-full object-cover object-top ring-1 ring-[var(--color-border)] sm:h-40 sm:w-40 lg:h-44 lg:w-44"
      />
      <p style="--hero-i: 1" class="mb-3 text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-accent)] sm:text-sm">
        Full-stack developer
      </p>
      <h1 style="--hero-i: 2" class="text-[2rem] font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
        Artem Zagaynov
      </h1>
      <p style="--hero-i: 3" class="mt-5 max-w-xl text-lg text-[var(--color-muted)]">
        I build complete systems, from AI-powered tools to distributed
        services, plus the occasional thing that makes everyday life feel
        seamless.
      </p>
      <div style="--hero-i: 4" class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/projects" class="btn-primary">See my work</a>
        <a
          href="/contact"
          class="rounded-full px-6 py-3 font-semibold text-[var(--color-fg)] ring-1 ring-[var(--color-border)] transition-colors hover:ring-[var(--color-accent)]"
        >
          Get in touch
        </a>
      </div>
    </div>

    <!-- scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-[var(--color-faint)]">
      <svg class="h-6 w-6 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
  </section>

  <!-- FEATURED WORK -->
  <section class="container-page py-20 sm:py-28">
    <div class="mb-10 flex items-end justify-between gap-4">
      <div>
        <h2 class="section-heading">Featured work</h2>
        <p class="mt-2 text-[var(--color-muted)]">
          A shipped system, and what I'm building now.
        </p>
      </div>
      <a
        href="/projects"
        class="hidden shrink-0 text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] sm:block"
      >
        All projects →
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2" data-reveal-group>
      {
        featured.map((p) => (
          <ProjectCard
            title={p.data.title}
            summary={p.data.summary}
            status={p.data.status}
            year={p.data.year}
            tags={p.data.tags}
            cover={p.data.cover}
            href={`/projects/${p.id}`}
            featured={false}
          />
        ))
      }
    </div>

    <a
      href="/projects"
      class="mt-8 block text-center text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] sm:hidden"
    >
      All projects →
    </a>
  </section>
</Layout>
