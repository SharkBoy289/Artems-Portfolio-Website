---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section
    class="relative flex min-h-[calc(100vh-4rem)] items-center justify-center overflow-hidden"
  >
    <!-- Hero interactive accent mounts here (lazy-loaded; static gradient fallback below) -->
    <div
      id="hero-canvas"
      class="pointer-events-none absolute inset-0 -z-10"
      aria-hidden="true"
    >
      <div
        class="absolute left-1/2 top-1/3 h-[480px] w-[480px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--color-accent)] opacity-[0.07] blur-[120px]"
      >
      </div>
    </div>

    <div class="container-page flex flex-col items-center text-center">
      <img
        src="/photos/artem.jpeg"
        alt="Artem Zagaynov"
        width="160"
        height="160"
        fetchpriority="high"
        class="mb-8 h-36 w-36 rounded-full object-cover ring-1 ring-[var(--color-border)]"
      />
      <h1
        class="text-4xl font-extrabold tracking-tight sm:text-6xl"
      >
        Artem Zagaynov
      </h1>
      <p
        class="mt-5 max-w-xl text-lg text-[var(--color-muted)]"
      >
        Full-stack developer crafting fast, responsive experiences across the
        web.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/projects" class="btn-primary">See my work</a>
        <a
          href="/contact"
          class="rounded-full px-6 py-3 font-semibold text-[var(--color-fg)] ring-1 ring-[var(--color-border)] transition-colors hover:ring-[var(--color-accent)]"
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>
</Layout>
