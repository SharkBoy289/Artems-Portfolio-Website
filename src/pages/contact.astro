---
import Layout from "../layouts/Layout.astro";

// Real links. Update handles as needed.
const socials = [
  {
    label: "Gmail",
    href: "mailto:Artemazag@gmail.com",
    // Gmail envelope mark (monochrome, matches the accent-filled icon set).
    icon: "M22 5.5v13a1.5 1.5 0 0 1-1.5 1.5H19V8.4l-7 5.25L5 8.4V20H3.5A1.5 1.5 0 0 1 2 18.5v-13A1.5 1.5 0 0 1 3.5 4h.4L12 10.2 20.1 4h.4A1.5 1.5 0 0 1 22 5.5z",
  },
  {
    label: "GitHub",
    href: "https://github.com/SharkBoy289",
    icon: "M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.15-1.1-1.46-1.1-1.46-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.56 9.56 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/artem-zagaynov",
    icon: "M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3V9zm6 0h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05C20.4 8.65 22 10.6 22 14v7h-4v-6.2c0-1.48-.03-3.38-2.06-3.38-2.06 0-2.38 1.6-2.38 3.27V21H9V9z",
  },
];
---

<Layout title="Contact | Artem Zagaynov">
  <section class="container-page py-16 sm:py-24">
    <div class="grid gap-12 sm:grid-cols-2">
      <!-- Working form via Web3Forms (no backend; AJAX submit).
           TODO: replace WEB3FORMS_ACCESS_KEY with your real key from web3forms.com -->
      <form id="contact-form" class="flex flex-col gap-4">
        <input type="hidden" name="access_key" value="WEB3FORMS_ACCESS_KEY" />
        <input type="hidden" name="subject" value="New message from your portfolio" />
        <input type="hidden" name="from_name" value="Portfolio Contact Form" />
        <!-- honeypot anti-spam -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <label class="sr-only" for="name">Your name</label>
        <input
          id="name"
          name="name"
          type="text"
          placeholder="Your name"
          required
          class="rounded-lg border border-[var(--color-border)] bg-transparent px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-faint)] focus:border-[var(--color-accent)] focus:outline-none"
        />
        <label class="sr-only" for="email">Your email</label>
        <input
          id="email"
          name="email"
          type="email"
          placeholder="Your email"
          required
          class="rounded-lg border border-[var(--color-border)] bg-transparent px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-faint)] focus:border-[var(--color-accent)] focus:outline-none"
        />
        <label class="sr-only" for="message">How can I help?</label>
        <textarea
          id="message"
          name="message"
          rows="6"
          placeholder="How can I help?"
          required
          class="rounded-lg border border-[var(--color-border)] bg-transparent px-4 py-3 text-[var(--color-fg)] placeholder:text-[var(--color-faint)] focus:border-[var(--color-accent)] focus:outline-none"
        ></textarea>
        <button type="submit" id="contact-submit" class="btn-primary self-start">
          Send
        </button>
        <p id="contact-status" class="text-sm" role="status" aria-live="polite"></p>
      </form>

      <!-- Info -->
      <div>
        <h1 class="section-heading text-3xl sm:text-4xl">Work with me</h1>
        <p class="mt-4 text-lg text-[var(--color-muted)]">
          I'm a graduate excited to take on full-stack development challenges
          and always eager to learn new skills.
        </p>

        <ul class="mt-8 flex flex-col gap-4">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  target={s.href.startsWith("http") ? "_blank" : undefined}
                  rel="noopener"
                  class="inline-flex items-center gap-3 text-[var(--color-muted)] transition-colors hover:text-[var(--color-fg)]"
                >
                  <svg
                    class="h-5 w-5 text-[var(--color-accent)]"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d={s.icon} />
                  </svg>
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("contact-status");
  const submit = document.getElementById("contact-submit");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const key = form.querySelector('[name="access_key"]').value;

    // If the access key hasn't been set yet, fall back to a mailto so the form
    // is never a dead end.
    if (key === "WEB3FORMS_ACCESS_KEY") {
      const data = new FormData(form);
      const body = encodeURIComponent(
        `From: ${data.get("name")} <${data.get("email")}>\n\n${data.get("message")}`,
      );
      window.location.href = `mailto:Artemazag@gmail.com?subject=Portfolio%20message&body=${body}`;
      return;
    }

    status.textContent = "Sending…";
    status.style.color = "var(--color-muted)";
    submit.disabled = true;

    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { Accept: "application/json" },
        body: new FormData(form),
      });
      const json = await res.json();
      if (json.success) {
        status.textContent = "Thanks, your message was sent. I'll get back to you soon.";
        status.style.color = "var(--color-accent)";
        form.reset();
      } else {
        throw new Error(json.message || "Something went wrong.");
      }
    } catch (err) {
      status.textContent =
        "Sorry, that didn't send. Email me directly at Artemazag@gmail.com.";
      status.style.color = "#f87171";
    } finally {
      submit.disabled = false;
    }
  });
</script>
