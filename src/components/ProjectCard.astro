---
import StatusBadge from "./StatusBadge.astro";

interface Props {
  title: string;
  summary: string;
  status: "shipped" | "in-progress" | "experiment";
  year: string;
  tags?: string[];
  cover?: string;
  href: string;
  featured?: boolean;
}
const {
  title,
  summary,
  status,
  year,
  tags = [],
  cover,
  href,
  featured = false,
} = Astro.props;
---

<a
  href={href}
  data-tilt
  data-reveal-stagger
  class:list={[
    "group relative flex flex-col overflow-hidden rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-surface)] transition-all duration-200 hover:border-[var(--color-accent)]/60 hover:shadow-[0_18px_40px_-20px_rgba(0,0,0,0.5)]",
    featured ? "sm:col-span-2" : "",
  ]}
>
  <div class="relative aspect-[16/9] w-full overflow-hidden bg-[var(--color-surface-2)]">
    {
      cover ? (
        <img
          src={cover}
          alt={`${title} cover`}
          loading="lazy"
          decoding="async"
          width="800"
          height="450"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
        />
      ) : (
        <div class="grid h-full w-full place-items-center text-[var(--color-faint)]">
          <span class="text-sm">{title}</span>
        </div>
      )
    }
  </div>

  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex items-center justify-between gap-3">
      <h3 class="text-lg font-semibold text-[var(--color-fg)]">{title}</h3>
      <span class="shrink-0 text-sm text-[var(--color-faint)]">{year}</span>
    </div>

    <StatusBadge status={status} />

    <p class="text-sm leading-relaxed text-[var(--color-muted)]">{summary}</p>

    {
      tags.length > 0 && (
        <ul class="mt-auto flex flex-wrap gap-1.5 pt-2">
          {tags.map((tag) => (
            <li class="rounded-md bg-[var(--color-surface-2)] px-2 py-0.5 text-xs text-[var(--color-muted)]">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</a>
